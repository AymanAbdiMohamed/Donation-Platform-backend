# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# Flask
FLASK_ENV=development
SECRET_KEY=replace-with-python-secrets-token-hex-32
JWT_SECRET_KEY=replace-with-python-secrets-token-hex-32

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Email (SMTP)
MAIL_USERNAME=your-smtp-username
MAIL_PASSWORD=your-smtp-password
MAIL_SERVER=smtp.mailtrap.io
MAIL_PORT=587

# M-Pesa Daraja API
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret
MPESA_SHORTCODE=your-shortcode
MPESA_PASSKEY=your-passkey
MPESA_CALLBACK_URL=https://your-domain.com/api/mpesa/callback
MPESA_PAYBILL_NUMBER=your-paybill
MPESA_ACCOUNT_NAME=YourAccountName
MPESA_MOCK_MODE=false

# Pesapal
PESAPAL_CONSUMER_KEY=your-consumer-key
PESAPAL_CONSUMER_SECRET=your-consumer-secret
PESAPAL_CALLBACK_URL=https://your-domain.com/api/pesapal/callback
PESAPAL_ENV=sandbox

# CORS
CORS_ORIGINS=http://localhost:5173

# Rate limiting (leave empty for in-memory, set Redis URL for production)
RATELIMIT_STORAGE_URI=

# Admin
ADMIN_EMAIL=admin@yourdomain.com
